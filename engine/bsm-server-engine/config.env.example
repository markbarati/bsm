# BSM Server Engine configuration
# Copy to config.env, edit it, then run:
#   sudo ./install.sh --config ./config.env --non-interactive
# Trusted shell environment file: do not add untrusted shell code.

DOMAIN="example.com"
SERVER_LABEL="oracle"
PUBLIC_IP=""
TIMEZONE="UTC"

APP_OWNER="ubuntu"
PUID="1000"
PGID="1000"

# Existing Hestia is detected and preserved. Enable only on a fresh OS.
INSTALL_HESTIA="no"
HESTIA_HOSTNAME="cp.example.com"
HESTIA_USER="hadmin"
HESTIA_EMAIL=""
HESTIA_PASSWORD=""

APPS="portainer homepage filebrowser uptime-kuma dozzle beszel gitea vaultwarden it-tools stirling-pdf webtop rdesktop"

PORT_PORTAINER="9443"
PORT_HOMEPAGE="3000"
PORT_UPTIME="3001"
PORT_GITEA="3002"
PORT_FILEBROWSER="18081"
PORT_DOZZLE="8082"
PORT_BESZEL="8090"
PORT_VAULTWARDEN="18084"
PORT_ITTOOLS="8085"
PORT_STIRLING="8086"
PORT_WEBTOP="13003"

INSTALL_CLOUDFLARED="yes"
CF_TUNNEL_TOKEN=""
CF_ACCESS_EMAIL=""

# cloudflare: recommended, no inbound RDP port
# public: exposes RDP_PUBLIC_PORT; restrict RDP_ALLOWED_CIDR
# disabled: do not deploy RDP
RDP_EXPOSURE="cloudflare"
RDP_LOCAL_PORT="18888"
RDP_PUBLIC_PORT="8888"
RDP_ALLOWED_CIDR=""
RDP_INSTALL_CHROMIUM="yes"
# Final pinned LinuxServer image. The moving ubuntu-xfce tag was removed after EOL.
RDESKTOP_IMAGE="lscr.io/linuxserver/rdesktop:ubuntu-xfce-version-80684ffb"
WEBTOP_IMAGE="lscr.io/linuxserver/webtop:ubuntu-xfce"
SKIP_ARCH_CHECK="no"

WEBTOP_USER="admin"
WEBTOP_PASSWORD=""
RDP_PASSWORD=""
VAULTWARDEN_SIGNUPS_ALLOWED="true"
GITEA_REGISTRATION="true"

BACKUP_ENABLE="no"
RCLONE_REMOTE="remote"
BACKUP_REMOTE_PATH="backups/server/full"
BACKUP_HOUR="04:15"
BACKUP_RETENTION_DAYS="14"
